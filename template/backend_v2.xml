<!-- 1. TRANSPORT -->
<!-- ============================================================ -->
<h2>1. Транспорт</h2>

<table>
<thead>
<tr><th style="width:240px">Параметр</th><th>Значение</th></tr>
</thead>
<tbody>
<tr><td><strong>Тип взаимодействия</strong></td><td><ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Blue</ac:parameter><ac:parameter ac:name="title">REST</ac:parameter></ac:structured-macro> <ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Purple</ac:parameter><ac:parameter ac:name="title">gRPC</ac:parameter></ac:structured-macro> <ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Yellow</ac:parameter><ac:parameter ac:name="title">Async (Broker)</ac:parameter></ac:structured-macro></td></tr>
<tr><td><strong>Протокол</strong></td><td>HTTP/1.1 | HTTP/2 | AMQP 0-9-1 | Kafka Protocol</td></tr>
</tbody>
</table>

<h3>1.1 Синхронный вызов (REST/gRPC)</h3>
<table>
<thead>
<tr><th>Параметр</th><th>Значение</th></tr>
</thead>
<tbody>
<tr><td><strong>Base URL</strong></td><td><code>https://[service].[env].internal/api/v1</code></td></tr>
<tr><td><strong>HTTP метод</strong></td><td><ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Green</ac:parameter><ac:parameter ac:name="title">GET</ac:parameter></ac:structured-macro> <ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Blue</ac:parameter><ac:parameter ac:name="title">POST</ac:parameter></ac:structured-macro> <ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Yellow</ac:parameter><ac:parameter ac:name="title">PUT</ac:parameter></ac:structured-macro> <ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Orange</ac:parameter><ac:parameter ac:name="title">PATCH</ac:parameter></ac:structured-macro> <ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Red</ac:parameter><ac:parameter ac:name="title">DELETE</ac:parameter></ac:structured-macro></td></tr>
<tr><td><strong>Auth</strong></td><td>Bearer JWT | Basic Auth | mTLS | Public</td></tr>
<tr><td><strong>Timeout</strong></td><td>[мс] — на чтение / на запись / общий</td></tr>
<tr><td><strong>Idempotency</strong></td><td>Да / Нет — если да: Header <code>Idempotency-Key: UUIDv4</code></td></tr>
<tr><td><strong>Content-Type</strong></td><td><code>application/json</code> | <code>application/protobuf</code> | <code>application/xml</code></td></tr>
</tbody>
</table>

<h3>1.2 Асинхронный (Message Broker)</h3>
<table>
<thead>
<tr><th>Параметр</th><th>Значение</th></tr>
</thead>
<tbody>
<tr><td><strong>Тип брокера</strong></td><td><ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Blue</ac:parameter><ac:parameter ac:name="title">RabbitMQ</ac:parameter></ac:structured-macro> <ac:structured-macro ac:name="status"><ac:parameter ac:name="colour">Purple</ac:parameter><ac:parameter ac:name="title">Kafka</ac:parameter></ac:structured-macro></td></tr>
<tr><td><strong>Exchange / Topic</strong></td><td><code>[exchange_name]</code> / <code>[topic_name]</code></td></tr>
<tr><td><strong>Routing Key</strong></td><td><code>[routing.pattern]</code> — если RabbitMQ</td></tr>
<tr><td><strong>Consumer Group</strong></td><td><code>[group_id]</code> — если Kafka</td></tr>
<tr><td><strong>Тип Exchange</strong></td><td>direct | topic | fanout | headers (только RabbitMQ)</td></tr>
<tr><td><strong>Durable</strong></td><td>Да / Нет — очередь переживает рестарт брокера</td></tr>
<tr><td><strong>Dead Letter Queue</strong></td><td><code>[dlq_name]</code> — куда падают необработанные сообщения</td></tr>
<tr><td><strong>Формат сообщения</strong></td><td>JSON | Avro | Protobuf — schema registry если применимо</td></tr>
<tr><td><strong>Delivery гарантии</strong></td><td>at-most-once | at-least-once | exactly-once</td></tr>
<tr><td><strong>Max retries</strong></td><td>[N] — количество повторных попыток перед DLQ</td></tr>
<tr><td><strong>Retry policy</strong></td><td>exponential-backoff | fixed-interval — параметры</td></tr>
</tbody>
</table>

