<!-- ============================================================ -->
<h2>5. Выходные данные</h2>

<h3>5.1 Успешный ответ</h3>
<table>
<thead>
<tr><th>Параметр</th><th>Значение</th></tr>
</thead>
<tbody>
<tr><td><strong>HTTP статус</strong></td><td>200 OK | 201 Created | 204 No Content | 202 Accepted</td></tr>
<tr><td><strong>Content-Type</strong></td><td><code>application/json</code></td></tr>
</tbody>
</table>

<table>
<thead>
<tr><th>Поле</th><th>Тип</th><th>Описание</th></tr>
