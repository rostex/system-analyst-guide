<h2>7. Модель данных</h2>

<table>
<thead>
<tr><th>Таблица</th><th>Операция</th><th>Поля</th><th>Индексы</th><th>FK</th></tr>
</thead>
<tbody>
<tr><td><code>[table]</code></td><td>INSERT | UPDATE | SELECT | DELETE</td><td>[field1, field2]</td><td><code>idx_[table]_[col]</code> ON ([col])</td><td><code>[col]</code> → <code>[ref_table].[ref_col]</code></td></tr>
</tbody>
</table>

<ac:structured-macro ac:name="code">
<ac:parameter ac:name="language">sql</ac:parameter>
<ac:plain-text-body><![CDATA[-- DDL (если новая таблица)
CREATE TABLE [table] (
    id         BIGSERIAL PRIMARY KEY,
    [field]    [type] [constraints],
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- DML (пример запроса из алгоритма)
INSERT INTO [table] ([fields]) VALUES ([values])
RETURNING id;]]></ac:plain-text-body>
</ac:structured-macro>

