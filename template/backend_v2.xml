</tbody>
</table>

<ac:structured-macro ac:name="code">
<ac:parameter ac:name="language">json</ac:parameter>
<ac:plain-text-body><![CDATA[{
  "eventType": "[event.type.name]",
  "eventId": "UUIDv4",
  "timestamp": "2026-07-15T12:00:00Z",
  "payload": {
    "[field]": "[value]"
  }
}]]></ac:plain-text-body>
</ac:structured-macro>

